describe "#${1:method}" do
  let(:mail) { ${2:MailerClass}.$1 }

  it "sets headers" do
    assert_headers "${4:subject}", [${5:user.email}]
  end

  it "uses valid images" do
    assert_valid_images(mail.body)
  end
end
